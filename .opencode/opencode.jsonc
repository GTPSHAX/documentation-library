{
  "$schema": "https://opencode.ai/config.json",

  "username": "center-docs",
  "share": "manual",
  "autoupdate": "notify",

  // Single entry point. Orchestra handles the full lifecycle internally.
  "default_agent": "orchestra",

  // Library entry points — Orchestra reads these before touching any library.
  "instructions": [
    "./README.md",
    "./sources.txt",
    "./opencode/AGENTS.md",
    "./daisyui/README.md",
    "./daisyui/CHANGELOG.md",
    "./express/README.md",
    "./reactjs/README.md",
    "./nextjs/README.md",
    "./astro/README.md",
    "./tailwindcss/README.md",
    "./nodejs/README.md",
    "./cpp/26.md",
    "./cmake/Help/index.rst",
    "./cloudflare/src/content/docs/content.config.ts",
    "./supabase/apps/docs/README.md",
    "./drizzle-orm/src/content/docs/overview.mdx",
    "./enet/include/enet/enet.h"
  ],

  "references": {},

  "watcher": {
    "ignore": [
      "scripts/",
      ".opencode/",
      "opencode/"
    ]
  },

  "tool_output": {
    "max_lines": 2000,
    "max_bytes": 102400
  }
}
